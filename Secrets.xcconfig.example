// Secrets.xcconfig.example
//
// Copy this file to Secrets.xcconfig (which is gitignored) and fill in the
// blanks below. The Xcode build references everything here through
// $(VAR_NAME) substitution — never hard-code these into Info.plist, source
// code, or the project file.
//
// ─── 1) Apple Developer Team ID ────────────────────────────────────────
//
// Find yours at https://developer.apple.com/account → Membership Details
// → "Team ID" (10-character alphanumeric, e.g. ABC123XY45).
// Used by code signing. Personal Team / free account also gets one.
DEVELOPMENT_TEAM = <YOUR_TEAM_ID>

// ─── 2) Mapbox public access token ─────────────────────────────────────
//
// Get one at https://account.mapbox.com/access-tokens/
// Recommended: restrict by bundle ID (e.g. eu.yourname.tripperdashpp).
// Referenced from Info.plist via $(MBX_ACCESS_TOKEN).
MBX_ACCESS_TOKEN = pk.YOU...HERE

// ─── 3) Mapbox SECRET download token (NOT here — goes in ~/.netrc) ─────
//
// scope: Downloads:Read
// Only needed at SDK fetch time (SPM resolution), never at runtime.
//
//   machine api.mapbox.com
//     login mapbox
//     password sk.YOUR_SECRET_DOWNLOAD_TOKEN

