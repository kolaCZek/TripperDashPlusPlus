<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- NOTE                                                          -->
	<!-- ───────────────────────────────────────────────────────────── -->
	<!--
	  This file is the *additional* Info.plist; Xcode generates the
	  baseline one (CFBundleIdentifier, CFBundleVersion, …) because
	  GENERATE_INFOPLIST_FILE = YES. Add only keys that aren't covered
	  by the build settings.
	-->

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- Background execution (Phase 6 will use these for real)        -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
		<string>processing</string>
	</array>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- Privacy strings (required by the App Store / iOS prompts)    -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TripperDash++ needs your location to show the bike position on the Tripper display.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>TripperDash++ continues streaming navigation to the Tripper display even when the phone screen is off.</string>

	<!-- Required by iOS 14+ for direct IP / Bonjour traffic on the LAN.
	     The Tripper AP lives at 192.168.1.1 over UDP. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>TripperDash++ needs to talk to the Royal Enfield Tripper dash over Wi-Fi (192.168.1.1).</string>

	<!-- No Bonjour service types yet; the key must exist or iOS blocks
	     the local-network prompt. Phase 7 may register `_tripper._tcp`. -->
	<key>NSBonjourServices</key>
	<array/>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- Export compliance                                            -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<!-- The only crypto we use is the RSA/PKCS1 handshake to the bike's
	     dash (CryptoKit / Security), which is standard, exempt encryption.
	     Declaring `false` lets every TestFlight / App Store upload skip
	     the manual export-compliance question and process automatically. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- App Transport Security                                       -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<!-- Allow plain UDP to 192.168.1.1 (the bike has no DNS / no TLS). -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- File sharing — expose the app's Documents/ in the Files app   -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<!--
	  These two keys together surface the app sandbox's Documents/
	  directory under Files → On My iPhone → TripperDash++, so the
	  per-session maneuver logs that `ManeuverLog` writes to
	  Documents/maneuver-logs/nav-<timestamp>.jsonl can be pulled off
	  the phone after a ride WITHOUT Xcode (AirDrop / copy to Files /
	  open in another app), then grepped or replayed offline.

	  - UIFileSharingEnabled: makes Documents/ visible over USB (Finder)
	    and in the Files app.
	  - LSSupportsOpeningDocumentsInPlace: lets the Files app open the
	    log files in place rather than importing a copy.

	  The logs contain raw GPS — see the PRIVACY note in ManeuverLog.swift.
	  They stay local: turning these on only exposes the sandbox to the
	  device owner via Files/Finder; nothing is uploaded. Toggle
	  `ManeuverLog.isEnabled = false` to stop writing them entirely.
	-->
	<key>UIFileSharingEnabled</key>
	<true/>

	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- Device requirements                                           -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>wifi</string>
	</array>

	<!-- Phone-only, portrait — the Tripper UI is steered from a thumb on
	     the bars, not by rotating the device. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- ───────────────────────────────────────────────────────────── -->
	<!-- Build provenance                                              -->
	<!-- ───────────────────────────────────────────────────────────── -->

	<!--
	  Short git commit SHA the binary was built from. This placeholder is
	  overwritten at build time by the `stamp-git-sha.sh` Run Script phase
	  (PlistBuddy writes into the built Info.plist). Surfaced in
	  Settings → Build → Version as "1.0 (46ab7a9)". A trailing "*" means
	  the working tree had uncommitted changes at build time.
	-->
	<key>GitCommitSHA</key>
	<string>dev</string>

</dict>
</plist>
