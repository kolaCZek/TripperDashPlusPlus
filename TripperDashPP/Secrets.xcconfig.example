//
// Secrets.xcconfig.example
//
// Copy this file to `Secrets.xcconfig` (which is gitignored) and fill
// in your own Mapbox public access token.
//
// The token MUST be of the form `pk.eyJ...` — public, URL-restricted
// to your bundle identifier (default `eu.kolaczek.tripperdashpp`).
//
// You also need the SECRET download token (`sk.…`, scope
// `Downloads:Read`) in `~/.netrc` so SPM can fetch the Mapbox SDK:
//
//   machine api.mapbox.com
//     login mapbox
//     password sk.YOUR_SECRET_DOWNLOAD_TOKEN
//
// Get both tokens from https://account.mapbox.com/access-tokens/.
//

MBX_ACCESS_TOKEN = pk.YOUR_PUBLIC_TOKEN_HERE
